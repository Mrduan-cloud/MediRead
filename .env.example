# ====== App ======
APP_NAME=MediRead
APP_ENV=dev
LOG_LEVEL=INFO
LOG_JSON=false
CORS_ORIGINS=["*"]

# ====== Security (生产必须改) ======
JWT_SECRET_KEY=please-change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 启动时引导的管理员 + 演示账号(生产务必改 ADMIN_PASSWORD)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=mediread-admin-2024
DEMO_PASSWORD=mediread2024
# 登录失败锁定策略:N 次失败锁 M 分钟
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# ====== LLM ======
# 默认：Ollama 私有化部署 GLM-4-9B-Chat (GGUF Q4_K_M 量化版)
#   单卡 RTX 4090 24G 即可流畅跑（也兼容 A10 24G / V100 32G / 显存 ≥ 12G 的其他卡）
#   Q4_K_M 比 Q4_0 精度更高，体检数据解读建议优先用这个
#   拉模型：docker compose exec ollama ollama pull glm4:9b-chat-q4_k_m
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=glm4:9b-chat-q4_k_m
LLM_TIMEOUT=90
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.2

# ====== Embedding & Reranker ======
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large
EMBEDDING_DIM=1024
MODEL_CACHE_DIR=/app/.cache/models

# ====== PaddleOCR ======
OCR_USE_GPU=false
OCR_LANG=ch
OCR_DET_MODEL_DIR=
OCR_REC_MODEL_DIR=
OCR_CLS_MODEL_DIR=

# ====== Milvus ======
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_MEDICAL=medical_kb

# ====== MySQL ======
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=mediread
MYSQL_PASSWORD=changeme
MYSQL_DB=mediread
MYSQL_ROOT_PASSWORD=root

# ====== Redis ======
REDIS_URL=redis://redis:6379/0

# ====== MinIO ======
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mediread
MINIO_SECURE=false

# ====== Upload limits ======
UPLOAD_MAX_BYTES=20971520
UPLOAD_ALLOWED_EXT=["jpg","jpeg","png","pdf"]

# ====== Observability ======
METRICS_ENABLED=true
METRICS_PATH=/metrics
SENTRY_DSN=
